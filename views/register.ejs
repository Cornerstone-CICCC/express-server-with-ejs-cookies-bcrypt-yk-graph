<h1 class="text-xl font-bold mb-4">Register</h1>
<form action="/api/auth/register" method="POST" class="flex flex-col items-center gap-4 w-80">
  <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-2 border rounded" />
  <input type="password" name="password" placeholder="Password" required class="w-full px-4 py-2 border rounded" />
  <button type="submit" class="bg-orange-700 text-white px-4 py-2 rounded">Register</button>
</form>
<a href="/login" class="text-orange-700 hover:underline">Login</a>
